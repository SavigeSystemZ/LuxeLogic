{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "MOS Plugin Manifest",
  "type": "object",
  "required": [
    "name",
    "version",
    "description",
    "hooks",
    "owned_paths",
    "requires"
  ],
  "properties": {
    "name": {
      "type": "string",
      "minLength": 1
    },
    "version": {
      "type": "string",
      "minLength": 1
    },
    "description": {
      "type": "string",
      "minLength": 1
    },
    "hooks": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "owned_paths": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "requires": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  },
  "additionalProperties": true
}
