APP_NAME="cache"
APP_ID="io.aiaast.cache"
APP_ENV=prod
APP_BIND_ADDRESS=127.0.0.1
APP_PORT=
APP_PORT_RANGE_START=8000
APP_PORT_RANGE_END=9000
APP_EXEC_START="python3 -m http.server ${APP_PORT:-8000}"
APP_HEALTHCHECK_URL=http://127.0.0.1:${APP_PORT:-8000}/health
DATABASE_MODE=postgres
POSTGRES_HOST=127.0.0.1
POSTGRES_PORT=5432
POSTGRES_DB=cache
POSTGRES_USER=cache
POSTGRES_PASSWORD=
SQLITE_PATH=${HOME}/.local/share/cache/app.sqlite3
LLM_CONFIG_PATH=ai/llm_config.yaml
SYSTEM_PACKAGES="python3 python3-venv curl"
