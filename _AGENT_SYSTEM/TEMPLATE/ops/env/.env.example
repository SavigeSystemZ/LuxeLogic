APP_NAME="TEMPLATE"
APP_ID="io.aiaast.template"
APP_ENV=prod
APP_BIND_ADDRESS=127.0.0.1
APP_PORT=
APP_PORT_RANGE_START=8000
APP_PORT_RANGE_END=9000
APP_EXEC_START="python3 -m http.server ${APP_PORT:-8000} --bind ${APP_BIND_ADDRESS:-127.0.0.1}"
APP_HEALTHCHECK_URL=http://${APP_BIND_ADDRESS:-127.0.0.1}:${APP_PORT:-8000}/health
DATABASE_MODE=postgres
POSTGRES_HOST_BIND=127.0.0.1
PUBLISH_POSTGRES_PORT=false
POSTGRES_HOST=${POSTGRES_HOST_BIND}
POSTGRES_PORT=5432
POSTGRES_DB=template
POSTGRES_USER=template
POSTGRES_PASSWORD=
REDIS_HOST_BIND=127.0.0.1
PUBLISH_REDIS_PORT=false
REDIS_HOST=${REDIS_HOST_BIND}
REDIS_PORT=6379
REDIS_USERNAME=
REDIS_PASSWORD=
REDIS_URL=redis://${REDIS_HOST}:${REDIS_PORT}/0
SQLITE_PATH=${HOME}/.local/share/template/app.sqlite3
LLM_CONFIG_PATH=ai/llm_config.yaml
SYSTEM_PACKAGES="python3 python3-venv curl"
